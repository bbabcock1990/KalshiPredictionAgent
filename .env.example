# --- Kalshi ---
# Demo first. Switch to production only when you trust the agents.
KALSHI_ENV=demo                      # demo | prod
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi-private-key.pem

# --- LLM ---
OPENAI_API_KEY=
LLM_MODEL=gpt-5-mini

# --- Data ---
NEWSAPI_KEY=
FRED_API_KEY=
TWITTER_BEARER_TOKEN=                # optional, enables X/Twitter social media fetches

# --- Risk ---
BANKROLL_USD=1000
MAX_STAKE_PCT=0.05                   # max 5% of bankroll per market
KELLY_FRACTION=0.25                  # quarter Kelly
MIN_EDGE=0.05                        # 5 cent edge required to GO
MIN_CONFIDENCE=0.5
MAX_SPREAD_CENTS=4
MIN_MINUTES_TO_CLOSE=60
